# ===============================================
# 5节点全栈集群统一Docker镜像构建文件
# 作用：构建包含所有大数据组件的统一镜像，支持5节点高密度部署
# 原理：基于基础镜像安装所有组件，使用Supervisor进行多进程管理
# 架构：支持Hadoop、Hive、HBase、ZooKeeper、Kafka、Flume、Spark、Flink全栈部署
# 内存限制：严格控制在16GB物理内存环境下运行
# ===============================================

# ===============================================
# 基础镜像选择
# 作用：使用预先构建的大数据基础镜像
# 原理：基础镜像已包含Java环境、SSH服务和基础工具
# 优势：避免重复安装基础软件包，减小镜像体积
# ===============================================
FROM bigdata-base:latest

# ===============================================
# 构建参数定义
# 作用：定义各组件版本参数，支持灵活的版本管理
# 原理：使用ARG指令定义构建时变量，便于版本升级和维护
# ===============================================

# Hadoop生态系统组件版本
ARG HADOOP_VERSION=3.1.3
ARG HIVE_VERSION=3.1.2
ARG HBASE_VERSION=2.2.3

# 分布式协调与消息组件版本
ARG ZOOKEEPER_VERSION=3.6.3
ARG KAFKA_VERSION=2.12-2.4.1

# 计算引擎组件版本
ARG SPARK_VERSION=3.1.1
ARG FLINK_VERSION=1.14.0

# 数据采集组件版本
ARG FLUME_VERSION=1.9.0

# 数据库组件版本
ARG MYSQL_VERSION=5.7

# ===============================================
# 环境变量设置
# 作用：设置各组件安装目录和系统路径
# 原理：确保容器内能正确找到各组件的位置和可执行文件
# ===============================================

# 组件安装目录
ENV HADOOP_HOME=/opt/hadoop
ENV HIVE_HOME=/opt/hive
ENV HBASE_HOME=/opt/hbase
ENV ZOOKEEPER_HOME=/opt/zookeeper
ENV KAFKA_HOME=/opt/kafka
ENV SPARK_HOME=/opt/spark
ENV FLINK_HOME=/opt/flink
ENV FLUME_HOME=/opt/flume

# 系统PATH变量
ENV PATH=$PATH:$HADOOP_HOME/bin:$HADOOP_HOME/sbin:$HIVE_HOME/bin:$HBASE_HOME/bin:$ZOOKEEPER_HOME/bin:$KAFKA_HOME/bin:$SPARK_HOME/bin:$FLINK_HOME/bin:$FLUME_HOME/bin

# 配置目录
ENV HADOOP_CONF_DIR=$HADOOP_HOME/etc/hadoop
ENV HIVE_CONF_DIR=$HIVE_HOME/conf
ENV HBASE_CONF_DIR=$HBASE_HOME/conf
ENV ZOOKEEPER_CONF_DIR=$ZOOKEEPER_HOME/conf
ENV KAFKA_CONF_DIR=$KAFKA_HOME/config
ENV SPARK_CONF_DIR=$SPARK_HOME/conf
ENV FLINK_CONF_DIR=$FLINK_HOME/conf
ENV FLUME_CONF_DIR=$FLUME_HOME/conf

# ===============================================
# Supervisor安装与配置
# 作用：安装进程管理工具，支持单容器多进程管理
# 原理：Supervisor可以监控和管理多个后台进程
# 重要性：5节点架构中单个节点需要运行多个服务
# ===============================================

RUN apt-get update && apt-get install -y supervisor && \
    mkdir -p /var/log/supervisor && \
    mkdir -p /etc/supervisor/conf.d

# 复制Supervisor基础配置文件
COPY config/supervisor/supervisord.conf /etc/supervisor/supervisord.conf

# ===============================================
# 组件安装阶段
# 作用：安装所有大数据组件到统一镜像中
# 原理：使用本地安装包避免网络下载，提高构建速度
# ===============================================

# ===============================================
# 组件安装阶段
# 作用：安装所有大数据组件到统一镜像中
# 原理：使用本地安装包避免网络下载，提高构建速度
# ===============================================

# 复制所有组件安装包
COPY module/hadoop-${HADOOP_VERSION}.tar.gz /tmp/
COPY module/apache-hive-${HIVE_VERSION}-bin.tar.gz /tmp/
COPY module/hbase-${HBASE_VERSION}-bin.tar.gz /tmp/
COPY module/apache-zookeeper-${ZOOKEEPER_VERSION}-bin.tar.gz /tmp/
COPY module/kafka_${KAFKA_VERSION}.tgz /tmp/
COPY module/apache-flume-${FLUME_VERSION}-bin.tar.gz /tmp/
COPY module/spark-${SPARK_VERSION}-bin-hadoop3.2.tgz /tmp/
COPY module/flink-1.14.0-bin-scala_2.12.tar /tmp/
COPY module/mysql-connector-java-5.1.49.jar /tmp/
COPY module/guava-27.0-jre.jar /tmp/

# 安装Hadoop
RUN tar -xzf /tmp/hadoop-${HADOOP_VERSION}.tar.gz -C /opt && \
    mv /opt/hadoop-${HADOOP_VERSION} $HADOOP_HOME && \
    rm /tmp/hadoop-${HADOOP_VERSION}.tar.gz

# 安装Hive
RUN tar -xzf /tmp/apache-hive-${HIVE_VERSION}-bin.tar.gz -C /opt && \
    mv /opt/apache-hive-${HIVE_VERSION}-bin $HIVE_HOME && \
    rm /tmp/apache-hive-${HIVE_VERSION}-bin.tar.gz

# 安装HBase
RUN tar -xzf /tmp/hbase-${HBASE_VERSION}-bin.tar.gz -C /opt && \
    mv /opt/hbase-${HBASE_VERSION} $HBASE_HOME && \
    rm /tmp/hbase-${HBASE_VERSION}-bin.tar.gz

# 安装ZooKeeper
RUN tar -xzf /tmp/apache-zookeeper-${ZOOKEEPER_VERSION}-bin.tar.gz -C /opt && \
    mv /opt/apache-zookeeper-${ZOOKEEPER_VERSION}-bin $ZOOKEEPER_HOME && \
    rm /tmp/apache-zookeeper-${ZOOKEEPER_VERSION}-bin.tar.gz

# 安装Kafka
RUN tar -xzf /tmp/kafka_${KAFKA_VERSION}.tgz -C /opt && \
    mv /opt/kafka_${KAFKA_VERSION} $KAFKA_HOME && \
    rm /tmp/kafka_${KAFKA_VERSION}.tgz

# 安装Flume
RUN tar -xzf /tmp/apache-flume-${FLUME_VERSION}-bin.tar.gz -C /opt && \
    mv /opt/apache-flume-${FLUME_VERSION}-bin $FLUME_HOME && \
    rm /tmp/apache-flume-${FLUME_VERSION}-bin.tar.gz

# 安装Spark
RUN tar -xzf /tmp/spark-${SPARK_VERSION}-bin-hadoop3.2.tgz -C /opt && \
    mv /opt/spark-${SPARK_VERSION}-bin-hadoop3.2 $SPARK_HOME && \
    rm /tmp/spark-${SPARK_VERSION}-bin-hadoop3.2.tgz

# 安装Flink
RUN tar -xf /tmp/flink-${FLINK_VERSION}-bin-scala_2.12.tar -C /opt && \
    mv /opt/flink-${FLINK_VERSION}-bin-scala_2.12 $FLINK_HOME && \
    rm /tmp/flink-${FLINK_VERSION}-bin-scala_2.12.tar

# ===============================================
# 依赖库兼容性处理
# 作用：解决组件间依赖库版本冲突问题
# 原理：统一使用基础镜像提供的兼容库版本
# ===============================================

# 复制MySQL JDBC驱动到Hive lib目录
RUN cp /tmp/mysql-connector-java-5.1.49.jar $HIVE_HOME/lib/

# 解决Hive和Hadoop Guava版本冲突
RUN rm -f $HIVE_HOME/lib/guava-*.jar && \
    cp /tmp/guava-27.0-jre.jar $HIVE_HOME/lib/

# 复制Hive配置文件模板
RUN cp $HIVE_HOME/conf/hive-default.xml.template $HIVE_HOME/conf/hive-site.xml

# 创建Hive仓库目录
RUN mkdir -p /opt/hive/warehouse && \
    mkdir -p /opt/hive/tmp

# 设置目录权限
RUN chmod 755 /opt/hive/warehouse && \
    chmod 755 /opt/hive/tmp

# ===============================================
# MySQL服务器安装
# 作用：安装MySQL数据库服务器
# 原理：使用apt-get安装MySQL服务器，配置基础环境
# ===============================================

# 安装MySQL服务器
RUN apt-get update && apt-get install -y mysql-server && \
    mkdir -p /var/lib/mysql /var/log/mysql /var/run/mysqld && \
    chown -R mysql:mysql /var/lib/mysql /var/log/mysql /var/run/mysqld

# ===============================================
# 目录结构创建
# 作用：创建可用组件运行所需的目录结构
# 原理：大数据组件需要特定的目录结构来存储数据和日志
# ===============================================

# ===============================================
# 目录结构创建
# 作用：创建所有组件运行所需的目录结构
# 原理：大数据组件需要特定的目录结构来存储数据和日志
# ===============================================

# 创建数据目录
RUN mkdir -p /opt/hadoop/data && \
    mkdir -p /opt/hive/data && \
    mkdir -p /opt/hbase/data && \
    mkdir -p /opt/zookeeper/data && \
    mkdir -p /opt/kafka/data && \
    mkdir -p /opt/flume/data && \
    mkdir -p /opt/spark/data && \
    mkdir -p /opt/flink/data

# 创建日志目录
RUN mkdir -p /opt/hadoop/logs && \
    mkdir -p /opt/hive/logs && \
    mkdir -p /opt/hbase/logs && \
    mkdir -p /opt/zookeeper/logs && \
    mkdir -p /opt/kafka/logs && \
    mkdir -p /opt/flume/logs && \
    mkdir -p /opt/flink/logs && \
    mkdir -p /opt/spark/logs && \
    mkdir -p /opt/flink/log

# 创建临时目录
RUN mkdir -p /opt/hadoop/tmp && \
    mkdir -p /opt/hive/tmp && \
    mkdir -p /opt/hbase/tmp && \
    mkdir -p /opt/spark/tmp && \
    mkdir -p /opt/flink/tmp

# ===============================================
# 配置文件复制
# 作用：将基础配置文件复制到镜像内
# 原理：支持配置热更新，便于调试和配置管理
# ===============================================

# 复制基础配置文件
COPY config/all-in-one/ /config/all-in-one/

# ===============================================
# 启动脚本配置
# 作用：复制并设置启动脚本的执行权限
# 原理：启动脚本负责根据节点角色启动相应的服务
# ===============================================

# 复制启动脚本
COPY scripts/all-in-one-entrypoint.sh /scripts/all-in-one-entrypoint.sh
RUN chmod +x /scripts/all-in-one-entrypoint.sh

# ===============================================
# 工作目录设置
# 作用：设置容器启动后的默认工作目录
# 原理：WORKDIR指令设置容器内的当前工作目录
# ===============================================

WORKDIR /opt

# ===============================================
# 容器启动配置
# 作用：设置容器的默认启动命令
# 原理：使用Supervisor作为主进程，管理所有子进程
# ===============================================

CMD ["/usr/bin/supervisord", "-c", "/etc/supervisor/supervisord.conf"]