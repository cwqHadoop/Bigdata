# ===============================================
# MySQL数据库服务器配置文件
# 作用：配置MySQL数据库服务器的基本参数、性能、安全等设置
# 原理：MySQL启动时读取此文件，建立数据库运行环境和连接配置
# 重要性：Hive等组件依赖MySQL存储元数据，影响整个大数据平台
# ===============================================

# ===============================================
# MySQL服务器配置段
# 作用：配置MySQL服务器进程的运行参数
# 原理：[mysqld]段包含服务器启动和运行的核心配置
# ===============================================
[mysqld]

# ===============================================
# 基本运行配置
# 作用：配置MySQL进程的基本运行参数
# 原理：指定运行用户、进程文件、套接字文件和数据目录
# ===============================================

# 基本配置
user = mysql
pid-file = /var/run/mysqld/mysqld.pid
socket = /var/run/mysqld/mysqld.sock
datadir = /var/lib/mysql

# ===============================================
# 网络连接配置
# 作用：配置MySQL服务器的网络监听参数
# 原理：指定服务器监听的地址和端口，允许远程连接
# ===============================================

# 服务器配置
bind-address = 0.0.0.0
port = 3306

# ===============================================
# 字符集配置
# 作用：配置MySQL服务器的默认字符集和排序规则
# 原理：utf8mb4支持完整的Unicode字符集，包括emoji表情
# ===============================================

# 字符集配置
character-set-server = utf8mb4
collation-server = utf8mb4_unicode_ci

# ===============================================
# 性能优化配置
# 作用：配置MySQL服务器的性能相关参数
# 原理：优化连接数、内存缓冲区和日志文件大小
# ===============================================

# 性能配置
max_connections = 1000
innodb_buffer_pool_size = 256M
innodb_log_file_size = 64M

# ===============================================
# 安全配置
# 作用：配置MySQL服务器的安全相关参数
# 原理：禁用域名解析提高性能，生产环境应启用密码验证
# ===============================================

# 安全配置
skip-name-resolve
# 注意：生产环境中应该设置密码验证插件
# default-authentication-plugin = mysql_native_password

# ===============================================
# 客户端配置段
# 作用：配置MySQL客户端的默认参数
# 原理：[client]段影响所有MySQL客户端的连接行为
# ===============================================
[client]
default-character-set = utf8mb4

# ===============================================
# MySQL命令行客户端配置段
# 作用：配置mysql命令行客户端的默认参数
# 原理：[mysql]段专门针对mysql命令行工具
# ===============================================
[mysql]
default-character-set = utf8mb4
