<?xml version="1.0"?>
<?xml-stylesheet type="text/xsl" href="configuration.xsl"?>
<!--
Hive数据仓库配置文件
作用：配置Hive数据仓库的元数据存储、数据仓库位置、执行环境等参数
原理：Hive启动时读取此文件，建立与MySQL数据库的连接和HDFS存储配置
重要性：Hive的核心配置文件，影响数据仓库的元数据管理和查询执行
-->
<configuration>
  <!--
  JDBC数据库连接配置
  作用：指定Hive元数据存储的MySQL数据库连接信息
  原理：Hive将表结构、分区信息等元数据存储在关系型数据库中
  连接参数：
    - mysql:3306: MySQL容器地址和端口
    - hive: 元数据数据库名称
    - createDatabaseIfNotExist: 自动创建数据库
    - useSSL=false: 禁用SSL连接（实验环境）
  -->
  <property>
    <name>javax.jdo.option.ConnectionURL</name>
    <value>jdbc:mysql://mysql:3306/hive?createDatabaseIfNotExist=true&amp;useSSL=false&amp;characterEncoding=UTF-8</value>
  </property>
  
  <!--
  JDBC驱动类名配置
  作用：指定MySQL JDBC驱动类名
  原理：Hive通过JDBC驱动与MySQL数据库建立连接
  驱动版本：使用兼容性较好的MySQL Connector/J驱动
  -->
  <property>
    <name>javax.jdo.option.ConnectionDriverName</name>
    <value>com.mysql.jdbc.Driver</value>
  </property>
  
  <!--
  数据库连接用户名配置
  作用：指定连接MySQL数据库的用户名
  原理：Hive使用此用户名访问元数据数据库
  安全考虑：生产环境应使用更复杂的用户名
  -->
  <property>
    <name>javax.jdo.option.ConnectionUserName</name>
    <value>hive</value>
  </property>
  
  <!--
  数据库连接密码配置
  作用：指定连接MySQL数据库的密码
  原理：Hive使用此密码进行数据库身份验证
  安全考虑：生产环境应使用强密码并加密存储
  -->
  <property>
    <name>javax.jdo.option.ConnectionPassword</name>
    <value>hive</value>
  </property>
  
  <!--
  Hive数据仓库目录配置
  作用：指定Hive表数据在HDFS中的存储位置
  原理：Hive将表数据以文件形式存储在HDFS的指定目录下
  路径说明：/user/hive/warehouse是Hive的默认数据仓库路径
  -->
  <property>
    <name>hive.metastore.warehouse.dir</name>
    <value>/user/hive/warehouse</value>
  </property>
  
  <!--
  Hive执行临时目录配置
  作用：指定Hive查询执行过程中产生的临时文件的存储位置
  原理：MapReduce作业在执行过程中会产生中间结果和临时文件
  路径说明：/tmp/hive用于存储查询执行过程中的临时数据
  -->
  <property>
    <name>hive.exec.scratchdir</name>
    <value>/tmp/hive</value>
  </property>
  
  <!--
  Hive Metastore服务配置
  作用：配置Hive元数据服务的相关参数
  原理：Metastore服务负责管理Hive的元数据信息
  重要性：确保Hive能够正确访问和管理表结构信息
  -->
  <property>
    <name>hive.server2.thrift.port</name>
    <value>10000</value>
  </property>
  <property>
    <name>hive.server2.thrift.bind.host</name>
    <value>0.0.0.0</value>
  </property>
  <property>
    <name>hive.metastore.uris</name>
    <value>thrift://hive-metastore:9083</value>
  </property>

  <property>
    <name>hive.execution.engine</name>
    <value>mr</value>
  </property>
  <property>
    <name>hive.server2.tez.initialize.default.sessions</name>
    <value>false</value>
  </property>
  <property>
    <name>hive.server2.tez.default.sessions</name>
    <value>0</value>
  </property>

  <property>
    <name>hive.support.concurrency</name>
    <value>true</value>
  </property>
  <property>
    <name>hive.txn.manager</name>
    <value>org.apache.hadoop.hive.ql.lockmgr.DbTxnManager</value>
  </property>
  <property>
    <name>hive.metastore.transactional.event.listeners</name>
    <value>org.apache.hive.hcatalog.listener.DbNotificationListener</value>
  </property>
  <property>
    <name>hive.metastore.event.db.notification.api.auth</name>
    <value>false</value>
  </property>

  <property>
    <name>hive.server2.enable.doAs</name>
    <value>false</value>
  </property>
  <property>
    <name>hive.exec.dynamic.partition</name>
    <value>true</value>
  </property>
  <property>
    <name>hive.exec.dynamic.partition.mode</name>
    <value>nonstrict</value>
  </property>
</configuration>