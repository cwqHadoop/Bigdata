<?xml version="1.0" encoding="UTF-8"?>
<?xml-stylesheet type="text/xsl" href="configuration.xsl"?>
<!--
Hadoop HDFS Site 配置文件
作用：专门配置HDFS分布式文件系统的参数，包括数据块管理、副本策略、NameNode/DataNode配置等
原理：HDFS组件启动时读取此文件，建立文件系统的存储和访问机制
-->
<configuration>
    <!--
    HDFS数据块副本数量配置
    作用：定义每个数据块在集群中的副本数量，影响数据可靠性和读取性能
    原理：HDFS将文件分割成数据块，并在不同DataNode上存储多个副本
    推荐值：通常设置为3，但实验环境可设为2以节省资源
    容错机制：当某个DataNode故障时，系统可以从其他副本恢复数据
    -->
    <property>
        <name>dfs.replication</name>
        <value>2</value>
    </property>
    
    <!--
    NameNode Web界面访问地址
    作用：指定NameNode Web管理界面的HTTP服务地址
    原理：用户可以通过此地址访问HDFS的Web管理界面，查看文件系统状态
    端口说明：9870是NameNode Web UI的标准端口
    安全考虑：生产环境应配置SSL和访问控制
    -->
    <property>
        <name>dfs.namenode.http-address</name>
        <value>namenode:9870</value>
    </property>
    
    <!--
    HDFS权限检查开关
    作用：控制是否启用HDFS的文件权限检查机制
    原理：启用时，HDFS会检查用户对文件的读写权限；关闭时，所有用户都有完全权限
    实验环境：为了方便测试，关闭权限检查
    生产环境：必须启用权限检查，确保数据安全
    -->
    <property>
        <name>dfs.permissions.enabled</name>
        <value>false</value>
    </property>
</configuration>
