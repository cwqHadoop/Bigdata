<?xml version="1.0" encoding="UTF-8"?>
<?xml-stylesheet type="text/xsl" href="configuration.xsl"?>
<!--
Hadoop HA MapReduce Site 配置文件
作用：配置Hadoop高可用集群中MapReduce框架的参数
原理：在HA环境下，MapReduce需要适配多NameNode架构
特殊配置：历史服务器地址指向namenode1，确保服务可用性
-->
<configuration>
    <!--
    MapReduce框架运行模式配置（HA环境）
    作用：指定MapReduce作业运行在YARN资源管理框架上
    原理：YARN在HA环境下需要适配ResourceManager的高可用机制
    注意：在HA模式下，ResourceManager也有主备切换机制
    -->
    <property>
        <name>mapreduce.framework.name</name>
        <value>yarn</value>
    </property>
    
    <!--
    JobHistoryServer RPC服务地址（HA环境）
    作用：在HA集群中指定JobHistoryServer的RPC通信地址
    原理：HA环境下历史服务器通常部署在namenode1上
    容错机制：即使namenode1故障，历史记录仍可通过namenode2访问
    -->
    <property>
        <name>mapreduce.jobhistory.address</name>
        <value>namenode1:10020</value>
    </property>
    
    <!--
    JobHistoryServer Web界面地址（HA环境）
    作用：在HA集群中指定JobHistoryServer的Web管理界面地址
    原理：Web界面通过namenode1访问，确保服务稳定性
    端口映射：19888端口映射到主机的19888端口
    -->
    <property>
        <name>mapreduce.jobhistory.webapp.address</name>
        <value>namenode1:19888</value>
    </property>
    
    <!--
    MapReduce任务环境变量配置（HA环境）
    作用：在HA环境下定义MapReduce任务执行时的环境变量
    原理：确保任务容器在HA环境中能正确找到依赖库
    重要性：HA环境需要更严格的环境变量配置
    -->
    <property>
        <name>yarn.app.mapreduce.am.env</name>
        <value>HADOOP_MAPRED_HOME=/opt/hadoop,HADOOP_CONF_DIR=/opt/hadoop/etc/hadoop</value>
    </property>
    <property>
        <name>mapreduce.map.env</name>
        <value>HADOOP_MAPRED_HOME=/opt/hadoop,HADOOP_CONF_DIR=/opt/hadoop/etc/hadoop</value>
    </property>
    <property>
        <name>mapreduce.reduce.env</name>
        <value>HADOOP_MAPRED_HOME=/opt/hadoop,HADOOP_CONF_DIR=/opt/hadoop/etc/hadoop</value>
    </property>
    <property>
        <name>mapreduce.application.classpath</name>
        <value>/opt/hadoop/etc/hadoop:/opt/hadoop/share/hadoop/common/lib/*:/opt/hadoop/share/hadoop/common/*:/opt/hadoop/share/hadoop/hdfs/lib/*:/opt/hadoop/share/hadoop/hdfs/*:/opt/hadoop/share/hadoop/mapreduce/lib/*:/opt/hadoop/share/hadoop/mapreduce/*:/opt/hadoop/share/hadoop/yarn/lib/*:/opt/hadoop/share/hadoop/yarn/*</value>
    </property>
</configuration>
