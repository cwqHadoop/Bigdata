<?xml version="1.0" encoding="UTF-8"?>
<?xml-stylesheet type="text/xsl" href="configuration.xsl"?>
<!-- ===============================================
Hadoop Master节点核心配置文件
作用：定义HDFS和MapReduce的全局配置参数
原理：配置NameNode和ResourceManager的基础参数
节点类型：master节点专用配置
=============================================== -->

<configuration>
    <!-- ===============================================
    HDFS默认文件系统配置
    作用：定义HDFS的默认文件系统URI
    原理：指定NameNode的服务地址和端口
    重要性：客户端通过此配置连接到HDFS
    =============================================== -->
    <property>
        <name>fs.defaultFS</name>
        <value>hdfs://master:9000</value>
        <description>HDFS默认文件系统URI，指向master节点的NameNode</description>
    </property>

    <!-- ===============================================
    Hadoop临时目录配置
    作用：定义Hadoop运行时使用的临时目录
    原理：用于存储临时文件和中间数据
    路径：使用容器内的绝对路径
    =============================================== -->
    <property>
        <name>hadoop.tmp.dir</name>
        <value>/opt/hadoop/data/tmp</value>
        <description>Hadoop临时文件目录</description>
    </property>

    <!-- ===============================================
    IO文件缓冲区大小配置
    作用：定义HDFS读写操作的缓冲区大小
    原理：优化IO性能，减少磁盘操作次数
    大小：64KB，适合小文件和大文件混合场景
    =============================================== -->
    <property>
        <name>io.file.buffer.size</name>
        <value>65536</value>
        <description>IO操作缓冲区大小(64KB)</description>
    </property>

    <!-- ===============================================
    内存优化配置
    作用：限制Hadoop组件的内存使用
    原理：通过JVM参数控制堆内存大小
    重要性：确保在16GB内存限制下稳定运行
    =============================================== -->
    <property>
        <name>hadoop.heap.size</name>
        <value>512</value>
        <description>NameNode堆内存大小(512MB)</description>
    </property>

    <!-- ===============================================
    网络配置
    作用：定义Hadoop集群内部通信参数
    原理：配置RPC和HTTP服务的地址绑定
    绑定地址：0.0.0.0表示监听所有网络接口
    =============================================== -->
    <property>
        <name>hadoop.rpc.server.address</name>
        <value>0.0.0.0</value>
        <description>RPC服务器地址绑定</description>
    </property>

    <!-- ===============================================
    数据节点通信配置
    作用：配置DataNode与NameNode的通信参数
    原理：定义DataNode服务地址和端口
    端口：50010是DataNode的默认数据传输端口
    =============================================== -->
    <property>
        <name>dfs.datanode.address</name>
        <value>0.0.0.0:50010</value>
        <description>DataNode数据传输地址</description>
    </property>

    <!-- ===============================================
    数据节点HTTP配置
    作用：配置DataNode的HTTP服务参数
    原理：用于Web UI和监控信息展示
    端口：50075是DataNode的默认HTTP端口
    =============================================== -->
    <property>
        <name>dfs.datanode.http.address</name>
        <value>0.0.0.0:50075</value>
        <description>DataNode HTTP服务地址</description>
    </property>

    <!-- ===============================================
    名称节点服务配置
    作用：配置NameNode的RPC服务参数
    原理：定义客户端与NameNode的通信接口
    端口：9000是NameNode的默认RPC端口
    =============================================== -->
    <property>
        <name>dfs.namenode.rpc-address</name>
        <value>master:9000</value>
        <description>NameNode RPC服务地址</description>
    </property>

    <!-- ===============================================
    名称节点HTTP配置
    作用：配置NameNode的HTTP服务参数
    原理：用于Web UI和文件系统浏览
    端口：9870是Hadoop 3.x的NameNode HTTP端口
    =============================================== -->
    <property>
        <name>dfs.namenode.http-address</name>
        <value>master:9870</value>
        <description>NameNode HTTP服务地址</description>
    </property>

    <!-- ===============================================
    资源管理器配置
    作用：配置YARN ResourceManager的服务地址
    原理：定义应用程序与ResourceManager的通信接口
    端口：8032是ResourceManager的默认调度器端口
    =============================================== -->
    <property>
        <name>yarn.resourcemanager.address</name>
        <value>master:8032</value>
        <description>ResourceManager服务地址</description>
    </property>

    <!-- ===============================================
    资源调度器配置
    作用：配置YARN调度器的服务地址
    原理：用于应用程序的资源调度请求
    端口：8030是ResourceManager的默认调度器端口
    =============================================== -->
    <property>
        <name>yarn.resourcemanager.scheduler.address</name>
        <value>master:8030</value>
        <description>ResourceManager调度器地址</description>
    </property>

    <!-- ===============================================
    资源跟踪器配置
    作用：配置YARN资源跟踪器的服务地址
    原理：用于NodeManager的资源汇报和心跳
    端口：8031是ResourceManager的默认资源跟踪器端口
    =============================================== -->
    <property>
        <name>yarn.resourcemanager.resource-tracker.address</name>
        <value>master:8031</value>
        <description>ResourceManager资源跟踪器地址</description>
    </property>

    <!-- ===============================================
    管理接口配置
    作用：配置YARN管理接口的服务地址
    原理：用于管理员命令和集群管理
    端口：8033是ResourceManager的默认管理接口端口
    =============================================== -->
    <property>
        <name>yarn.resourcemanager.admin.address</name>
        <value>master:8033</value>
        <description>ResourceManager管理接口地址</description>
    </property>

    <!-- ===============================================
    Web应用代理配置
    作用：配置YARN Web应用代理的服务地址
    原理：用于应用程序的Web UI代理
    端口：8088是ResourceManager的默认Web UI端口
    =============================================== -->
    <property>
        <name>yarn.resourcemanager.webapp.address</name>
        <value>master:8088</value>
        <description>ResourceManager Web UI地址</description>
    </property>

</configuration>