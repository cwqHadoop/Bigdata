<?xml version="1.0"?>
<?xml-stylesheet type="text/xsl" href="configuration.xsl"?>
<!--
HBase分布式数据库配置文件
作用：配置HBase集群的存储位置、ZooKeeper连接、分布式模式等参数
原理：HBase启动时读取此文件，建立与HDFS和ZooKeeper的连接
重要性：HBase的核心配置文件，影响数据存储和集群协调
-->
<configuration>
  <!--
  HBase根目录配置（动态替换）
  作用：指定HBase元数据和表数据在HDFS中的存储根目录
  原理：启动脚本会根据实际环境动态替换此占位符
  占位符说明：HBASE_ROOTDIR_PLACEHOLDER将在运行时替换为实际HDFS路径
  -->
  <property>
    <name>hbase.rootdir</name>
    <value>HBASE_ROOTDIR_PLACEHOLDER</value>
  </property>
  
  <!--
  ZooKeeper集群配置
  作用：指定HBase使用的ZooKeeper集群节点地址
  原理：HBase依赖ZooKeeper进行集群协调、元数据管理和故障检测
  节点配置：使用3节点ZooKeeper集群确保高可用性
  -->
  <property>
    <name>hbase.zookeeper.quorum</name>
    <value>zoo1,zoo2,zoo3</value>
  </property>
  
  <!--
  ZooKeeper数据目录配置
  作用：指定ZooKeeper在容器内的数据存储目录
  原理：ZooKeeper将集群状态和元数据存储在此目录
  路径说明：/data/zookeeper是ZooKeeper的默认数据目录
  -->
  <property>
    <name>hbase.zookeeper.property.dataDir</name>
    <value>/data/zookeeper</value>
  </property>
  
  <!--
  HBase集群分布式模式配置
  作用：启用HBase的分布式集群模式
  原理：分布式模式下，HBase在多个节点上运行RegionServer
  模式说明：
    - true: 分布式模式（生产环境）
    - false: 单机模式（开发测试）
  -->
  <property>
    <name>hbase.cluster.distributed</name>
    <value>true</value>
  </property>
  
  <!--
  HBase Master Web管理界面端口配置
  作用：指定HBase Master Web管理界面的服务端口
  原理：用户可以通过Web界面监控HBase集群状态
  端口说明：16010是HBase Master Web UI的标准端口
  -->
  <property>
    <name>hbase.master.info.port</name>
    <value>16010</value>
  </property>
  
  <!-- RegionServer Web UI端口 -->
  <property>
    <name>hbase.regionserver.info.port</name>
    <value>16030</value>
  </property>
  
  <!-- HBase Master绑定地址 -->
  <property>
    <name>hbase.master</name>
    <value>0.0.0.0</value>
  </property>
  
  <!-- 启用HBase REST服务 -->
  <property>
    <name>hbase.rest.port</name>
    <value>8080</value>
  </property>
  
  <!-- 启用HBase Thrift服务 -->
  <property>
    <name>hbase.thrift.port</name>
    <value>9090</value>
  </property>

  <!-- 解决HDFS不支持hflush/hsync导致的启动失败问题 -->
  <property>
    <name>hbase.unsafe.stream.capability.enforce</name>
    <value>false</value>
    <description>强制关闭流能力检查，允许在不支持hflush的HDFS上运行HBase</description>
  </property>

</configuration>